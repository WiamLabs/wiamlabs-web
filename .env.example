NEXT_PUBLIC_SITE_URL=https://wiamlabs.com
NEXT_PUBLIC_WIAMAPP_URL=https://wiamapp.com
NEXT_PUBLIC_WIAMTRADE_URL=https://wiamtrade.wiamlabs.com
NEXT_PUBLIC_WIAMPASS_URL=https://wiampass.com

# ── Shared Paystack webhook router (app/api/webhook/paystack) ──
# One Paystack account, one webhook URL, routed here to each
# product's own real backend. Server-side only — never NEXT_PUBLIC_.
PAYSTACK_SECRET_KEY=
WIAMAPP_WEBHOOK_URL=https://your-wiamapp-backend.onrender.com/api/webhooks/paystack
WIAMPASS_WEBHOOK_URL=https://your-wiampass-api.onrender.com/v1/payments/webhooks/paystack

# ── Central checkout (app/api/checkout/initiate) ────────────────
# Where "Pay" on /[product]/pricing actually starts a charge.
# See docs/CHECKOUT_SPEC.md for what each endpoint must implement.
WIAMAPP_CHECKOUT_URL=https://your-wiamapp-backend.onrender.com/api/payments/paystack/subscribe-by-email

# Brevo (free: 300 emails/day, own wiamlabs.com domain — separate from Resend/WiamApp)
# https://www.brevo.com — SMTP & API → Create API key
BREVO_API_KEY=
# Where form submissions are delivered (your real inbox)
CONTACT_TO_EMAIL=martin@wiamlabs.com
# Public sender address on wiamlabs.com (verified in Brevo)
CONTACT_FROM_EMAIL=hello@wiamlabs.com
CONTACT_FROM_NAME=WiamLabs

# Phase 3 CMS (optional — site uses JSON until enabled)
# CMS_ENABLED=true
# NEXT_PUBLIC_CMS_API_URL=https://api.wiamlabs.com
# REVALIDATE_SECRET=
